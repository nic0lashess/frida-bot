# --- Cible ---
TARGET_DATE=2026-05-04          # YYYY-MM-DD
TICKETS=4                       # nombre de billets
TICKET_TYPE=general             # general | national | student | senior

# --- Acheteur (pré-rempli dans le panier) ---
BUYER_NAME=Hadrien
BUYER_LAST_NAME=
BUYER_EMAIL=hadrien.gs@gmail.com
BUYER_PHONE=+33...              # format international

# --- WhatsApp ---
# Numéro WhatsApp destinataire des notifs (TON propre numéro), format international sans + ni espaces.
# Ex: 33612345678
WHATSAPP_OWNER=

# --- Polling ---
CHECK_CRON=*/2 * * * *          # toutes les 2 minutes
SLOT_PROPOSAL_TIMEOUT_MIN=10
PAYMENT_LINK_TIMEOUT_MIN=15

# --- Site ---
TICKET_URL=https://boletos.museofridakahlo.org.mx/es/tickets/museo-frida-kahlo-cdmx

# --- Debug ---
HEADED=false                    # true pour voir le navigateur Playwright
LOG_LEVEL=info
